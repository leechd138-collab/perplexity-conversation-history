{
  "manifest_version": 3,
  "name": "NaughtyBits",
  "version": "2.0.0",
  "description": "Autonomous AI companion — persistent memory, process management, and session continuity",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://www.perplexity.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.perplexity.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NaughtyBits Dashboard"
  }
}
